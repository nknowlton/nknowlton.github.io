---
import { pageMeta, siteMeta, type Locale, type PageSlug } from "../data/site";
import { publications } from "../data/publications";
import { aboutContent, joinContent, outcomeClass, peopleContent, researchStreams, teachingContent } from "../data/sections";
interface Props { locale: Locale; page: PageSlug; }
const { locale, page } = Astro.props;
const meta = pageMeta[page][locale];
---
<section class="page-hero shell-wide"><p class="kicker">{meta.eyebrow}</p><h1>{meta.title}</h1><p>{meta.description}</p></section>

{page === "about" && <div class="page-body shell-wide"><section class="prose-lead"><h2>Translational statistical science</h2><p>{aboutContent.intro}</p></section><div class="principle-grid">{aboutContent.principles.map((item, i) => <article><span>0{i + 1}</span><h3>{item.title}</h3><p>{item.body}</p></article>)}</div><section class="split-section"><div><p class="mono-label">Affiliations</p><h2>One research environment across two institutions.</h2></div><ul>{aboutContent.affiliations.map((item) => <li>{item}</li>)}</ul></section></div>}

{page === "research" && <div class="page-body shell-wide"><div class="case-list">{researchStreams.map((stream, i) => <article class="research-case" id={stream.area === "Reproductive AI" ? "reproductive-ai" : undefined}><header><span>0{i + 1} · {stream.area}</span><h2>{stream.question}</h2><div class="tag-list">{stream.outcomes.map((tag) => <span class:list={["outcome-tag", outcomeClass[tag] ?? "tag-teaching"]}>{tag}</span>)}</div></header><div class="case-arc"><div><b>Clinical problem</b><p>{stream.problem}</p></div><div><b>Statistical method</b><p>{stream.method}</p></div><div><b>Where it landed</b><p>{stream.landed}</p></div></div>{stream.area === "Reproductive AI" && <a class="wyld-button" href={siteMeta.wyldBloom} target="_blank" rel="noreferrer">Explore WyldBloom ↗</a>}</article>)}</div></div>}

{page === "students" && <div class="page-body shell-wide"><section class="prose-lead"><h2>One methods and manuscript-development environment.</h2><p>Students at Massey and Auckland share questions, methods, datasets, and the work of turning analysis into clear evidence.</p></section><div class="people-columns">{peopleContent.groups.map((group) => <section><h2>{group.title}</h2>{group.people.map(([name, role, question]) => <article class="directory-row"><div><b>{name}</b><span>{role}</span></div><p>“{question}”</p></article>)}</section>)}</div><section class="split-section"><div><p class="mono-label">Completed MSc</p><h2>Alumni</h2></div><ul>{peopleContent.alumni.map((person) => <li>{person}</li>)}</ul></section></div>}

{page === "teaching" && <div class="page-body shell-wide"><section class="teaching-lead"><p class="mono-label">Teaching philosophy</p><h2>{teachingContent.philosophy}</h2><p>{teachingContent.body}</p></section><div class="course-layout"><aside><span>Course index</span>{teachingContent.courses.map((course, i) => <a href={`#course-${i + 1}`}>{course.code}</a>)}</aside><div>{teachingContent.courses.map((course, i) => <article class="course-row" id={`course-${i + 1}`}><span>{course.code}</span><div><h2>{course.title}</h2><div class="course-actions"><a href={course.href} target="_blank" rel="noreferrer">Course information ↗</a>{course.resources && <a href={course.resources}>Hosted materials →</a>}</div></div></article>)}</div></div></div>}

{page === "publications" && <div class="page-body shell-wide"><div class="publication-table full">{publications.map((pub) => <a class="publication-row" href={pub.href} target="_blank" rel="noreferrer"><div><b>{pub.title}</b><span>{pub.venue}<br />{pub.summary}</span></div><time>{pub.year}</time><div class="tag-list">{pub.outcomes.map((tag) => <span class:list={["outcome-tag", outcomeClass[tag] ?? "tag-teaching"]}>{tag}</span>)}</div></a>)}</div><section class="profile-links"><p>Complete scholarly record</p><a href={siteMeta.socialLinks[2].href} target="_blank" rel="noreferrer">Google Scholar ↗</a><a href={siteMeta.socialLinks[3].href} target="_blank" rel="noreferrer">ORCID ↗</a></section></div>}

{page === "join" && <div class="page-body shell-wide"><section class="join-page"><div><p class="mono-label">Mentorship</p><h2>{joinContent.lead}</h2><p>{joinContent.body}</p><a class="primary-button" href={`mailto:${siteMeta.email}`}>{siteMeta.email} →</a></div><div><h3>Shared values</h3><ul>{joinContent.values.map((item) => <li>{item}</li>)}</ul><h3>What to send</h3><ul>{joinContent.send.map((item) => <li>{item}</li>)}</ul></div></section></div>}
