---
import {
  aboutContent,
  pageMeta,
  publicationContent,
  researchThemes,
  siteMeta,
  studentGroups,
  teachingContent,
  uiText,
  type Locale,
  type PageSlug
} from "../data/site";

interface Props {
  locale: Locale;
  page: PageSlug;
}

const { locale, page } = Astro.props;
const meta = pageMeta[page][locale];
const ui = uiText[locale];
---

<section class="shell py-10 sm:py-14">
  <div class="panel px-6 py-8 sm:px-8 sm:py-10">
    <p class="eyebrow">{meta.eyebrow}</p>
    <h1 class="mt-4 max-w-4xl text-5xl leading-[1.05] text-sand-100 sm:text-6xl">{meta.title}</h1>
    <p class="muted-copy mt-6 max-w-3xl text-lg">{meta.description}</p>
  </div>
</section>

{page === "about" && (
  <section class="shell pb-16">
    <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <article class="panel px-6 py-8 sm:px-8">
        <h2 class="section-title text-sand-100">Knowlton Lab</h2>
        <p class="muted-copy mt-4">{aboutContent.intro}</p>

        <div class="mt-8 section-grid">
          {aboutContent.principles.map((item, i) => {
            const accentColors = [
              "border-aqua-400/30",
              "border-coral-400/30",
              "border-gold-300/30"
            ];
            return (
              <article class={`rounded-[1.5rem] border ${accentColors[i % accentColors.length]} bg-white/[0.04] px-5 py-5 shadow-sm transition hover:-translate-y-0.5 hover:bg-white/[0.07]`}>
                <h3 class="text-2xl text-sand-100">{item.title}</h3>
                <p class="muted-copy mt-3">{item.body}</p>
              </article>
            );
          })}
        </div>
      </article>

      <aside class="panel px-6 py-8 sm:px-7">
        <p class="eyebrow">Affiliations</p>
        <ul class="mt-5 space-y-4">
          {aboutContent.affiliations.map((item) => (
            <li class="flex gap-3">
              <span class="mt-2 h-2.5 w-2.5 rounded-full bg-aqua-400"></span>
              <span class="text-base leading-7 text-sand-100/80">{item}</span>
            </li>
          ))}
        </ul>

        <div class="mt-8 rounded-[1.5rem] border border-white/10 bg-white/5 p-5">
          <p class="eyebrow">Contact</p>
          <a class="mt-3 block text-lg text-aqua-400 hover:text-aqua-400/80" href={`mailto:${siteMeta.email}`}>
            {siteMeta.email}
          </a>
          <p class="mt-4 text-sm text-sand-100/72">
            Applied statistics, machine learning, and translational biomedical collaboration.
          </p>
        </div>
      </aside>
    </div>
  </section>
)}

{page === "research" && (
  <section class="shell pb-16">
    <div class="section-grid">
      {researchThemes.map((theme) => {
        const accentMap = {
          coral: { border: "border-coral-400/40", bg: "bg-coral-400/10", icon: "text-coral-400", iconPath: "M12 4a4 4 0 014 4c0 1.473-.828 2.75-2 3.414V18a2 2 0 11-4 0v-6.586A4.982 4.982 0 018 8a4 4 0 014-4z" },
          aqua: { border: "border-aqua-400/40", bg: "bg-aqua-400/10", icon: "text-aqua-400", iconPath: "M12 2a10 10 0 100 20 10 10 0 000-20zm-2 14.5v-9l6 4.5-6 4.5z" },
          gold: { border: "border-gold-300/40", bg: "bg-gold-300/10", icon: "text-gold-300", iconPath: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" }
        };
        const a = accentMap[theme.accent];

        return (
          <article class={`panel relative overflow-hidden px-6 py-7 transition hover:-translate-y-0.5 ${a.border} border-l-[6px]`}>
            <div class={`absolute right-[-2rem] top-[-2rem] h-32 w-32 rounded-full ${a.bg} blur-2xl`}></div>
            <div class="relative flex items-start gap-4">
              <span class={`flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl border border-white/10 bg-white/5 ${a.icon}`}>
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d={a.iconPath}/></svg>
              </span>
              <div>
                <h2 class="card-title">{theme.title}</h2>
                <p class="muted-copy mt-3">{theme.body}</p>
                <div class="mt-4 flex flex-wrap gap-2">
                  {theme.methods.map((method) => (
                    <span class="chip">{method}</span>
                  ))}
                </div>
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>
)}

{page === "students" && (
  <section class="shell pb-16">
    <div class="grid gap-6 lg:grid-cols-[1fr_1fr]">
      <article class="panel px-6 py-7">
        <p class="eyebrow">PhD</p>
        <h2 class="card-title mt-3">Current doctoral students</h2>
        <div class="mt-5 space-y-3">
          {studentGroups.phd.map((student) => (
            <a
              href={student.href}
              target="_blank"
              rel="noreferrer"
              class="group flex items-center gap-4 rounded-2xl border border-white/10 bg-ink-900/40 px-5 py-4 transition hover:border-aqua-400/35 hover:bg-white/5"
            >
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-sm font-semibold text-aqua-400 transition group-hover:border-aqua-400/40">
                {student.label.split(" ").map(n => n[0]).join("")}
              </span>
              <div class="min-w-0">
                <div class="text-base font-semibold text-sand-100">{student.label}</div>
                <div class="text-sm text-sand-100/72">{student.detail}</div>
              </div>
              <svg class="ml-auto h-4 w-4 shrink-0 text-sand-100/40 transition group-hover:text-aqua-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
            </a>
          ))}
        </div>
      </article>

      <div class="grid gap-6 content-start">
        <article class="panel px-6 py-7">
          <p class="eyebrow">Alumni</p>
          <h2 class="card-title mt-3">Lab Alumni</h2>
          <div class="mt-5 space-y-3">
            {studentGroups.masters.map((student) => (
              <a
                href={student.href}
                target="_blank"
                rel="noreferrer"
                class="group flex items-center gap-4 rounded-2xl border border-white/10 bg-ink-900/40 px-5 py-4 transition hover:border-coral-400/35 hover:bg-white/5"
              >
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-sm font-semibold text-coral-400 transition group-hover:border-coral-400/40">
                  {student.label.split(" ").map(n => n[0]).join("")}
                </span>
                <div class="min-w-0">
                  <div class="text-base font-semibold text-sand-100">{student.label}</div>
                  <div class="text-sm text-sand-100/72">{student.detail}</div>
                </div>
                <svg class="ml-auto h-4 w-4 shrink-0 text-sand-100/40 transition group-hover:text-coral-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
              </a>
            ))}
          </div>
        </article>

        <aside class="panel px-6 py-7">
          <p class="eyebrow">{ui.currentStudents}</p>
          <h2 class="card-title mt-3">Mentoring priorities</h2>
          <p class="muted-copy mt-4">{studentGroups.mentoring}</p>
        </aside>
      </div>
    </div>
  </section>
)}

{page === "teaching" && (
  <section class="shell pb-16">
    <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
      <article class="panel px-6 py-7">
        <p class="eyebrow">Courses</p>
        <h2 class="card-title mt-3">Current teaching</h2>
        <div class="mt-5 grid gap-4">
          {teachingContent.courses.map((course) => (
            <a
              href={course.href}
              class="rounded-[1.4rem] border border-white/10 bg-ink-900/56 px-5 py-5 transition hover:border-aqua-400/35"
              target="_blank"
              rel="noreferrer"
            >
              <div class="text-xl text-sand-100">{course.title}</div>
              {course.note && <div class="mt-2 text-sm text-sand-100/72">{course.note}</div>}
            </a>
          ))}
        </div>
      </article>

      <aside class="grid gap-6">
        <article class="panel px-6 py-7">
          <p class="eyebrow">{ui.courseResources}</p>
          <h2 class="card-title mt-3">Hosted materials</h2>
          <ul class="mt-5 space-y-4">
            {teachingContent.resources.map((resource) => (
              <li>
                <a class="text-base text-aqua-400 hover:text-aqua-400/80" href={resource.href}>
                  {resource.label}
                </a>
              </li>
            ))}
          </ul>
        </article>

        <article class="panel px-6 py-7">
          <p class="eyebrow">Approach</p>
          <h2 class="card-title mt-3">How the courses are framed</h2>
          <p class="muted-copy mt-4">{teachingContent.philosophy}</p>
        </article>
      </aside>
    </div>
  </section>
)}

{page === "publications" && (
  <section class="shell pb-16">
    <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
      <article class="panel px-6 py-7">
        <p class="eyebrow">Selected publications</p>
        <h2 class="card-title mt-3">Recent work across imaging, fertility, and translational analytics</h2>
        <p class="muted-copy mt-4">{publicationContent.intro}</p>

        <div class="mt-6 space-y-4">
          {publicationContent.featured.map((publication) => (
            <article class="rounded-[1.5rem] border border-white/10 bg-white/[0.04] px-5 py-5 shadow-sm transition hover:-translate-y-0.5 hover:bg-white/[0.07]">
              <div class="flex flex-wrap items-center gap-3">
                <span class="chip">{publication.year}</span>
                <span class="text-sm font-medium text-sand-100/72">{publication.venue}</span>
              </div>
              <h3 class="mt-4 text-xl font-semibold leading-snug text-sand-100 sm:text-2xl">{publication.title}</h3>
              <p class="muted-copy mt-3">{publication.summary}</p>
              <div class="mt-4 flex flex-wrap gap-2">
                {publication.tags.map((tag) => (
                  <span class="chip">{tag}</span>
                ))}
              </div>
              <a
                class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-aqua-400 transition hover:text-aqua-400/80"
                href={publication.href}
                target="_blank"
                rel="noreferrer"
              >
                {ui.readAbstract}
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
              </a>
            </article>
          ))}
        </div>
      </article>

      <aside class="grid gap-6 content-start">
        <article class="panel px-6 py-7">
          <p class="eyebrow">Profiles</p>
          <h2 class="card-title mt-3">Full publication record</h2>
          <ul class="mt-5 space-y-4">
            {publicationContent.externalProfiles.map((profile) => (
              <li>
                <a
                  class="inline-flex items-center gap-2 text-base text-aqua-400 transition hover:text-aqua-400/80"
                  href={profile.href}
                  target="_blank"
                  rel="noreferrer"
                >
                  {profile.label}
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </article>

        <article class="panel px-6 py-7">
          <p class="eyebrow">Coverage</p>
          <h2 class="card-title mt-3">What is included here</h2>
          <p class="muted-copy mt-4">
            This page presents a curated site-level selection rather than a full bibliography. The broader record remains available through Google Scholar and ORCID.
          </p>
        </article>
      </aside>
    </div>
  </section>
)}
