---
import { siteMeta, type Locale } from "../data/site";

interface Props {
  locale: Locale;
}

const { locale: _locale } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-white/10 py-12">
  <div class="shell grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
    <div class="space-y-3">
      <p class="eyebrow">Contact</p>
      <h2 class="text-3xl text-sand-100">Collaborate on translational methods that can survive reality.</h2>
      <a class="text-lg text-aqua-400 hover:text-aqua-400/80" href={`mailto:${siteMeta.email}`}>
        {siteMeta.email}
      </a>
      <p class="text-sm text-sand-100/72">
        {siteMeta.institutions.join(" | ")} | {currentYear}
      </p>
    </div>

    <div class="grid gap-3 sm:grid-cols-2">
      {siteMeta.socialLinks.map((link) => (
        <a
          href={link.href}
          class="group flex items-center gap-3 rounded-3xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-sand-100/72 transition hover:border-aqua-400/35 hover:text-sand-100"
          target="_blank"
          rel="noreferrer"
        >
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-xs transition group-hover:border-aqua-400/30">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10"/></svg>
          </span>
          {link.label}
        </a>
      ))}
    </div>

    <div class="col-span-full mt-4 flex flex-wrap items-center gap-6 border-t border-white/10 pt-6">
      <span class="text-xs uppercase tracking-[0.18em] text-sand-100/45">Institutional partners</span>
      <span class="text-sm font-medium text-sand-100/72">Massey University</span>
      <span class="text-sm font-medium text-sand-100/72">University of Auckland</span>
    </div>
  </div>
</footer>
