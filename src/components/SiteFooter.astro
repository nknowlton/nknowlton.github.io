---
import { navigationLabels, pageSlugs, siteMeta, type Locale } from "../data/site";
import { getLocalizedPath } from "../lib/routing";
interface Props { locale: Locale; }
const { locale } = Astro.props;
---
<footer class="footer">
  <div class="footer-inner">
    <div>
      <h2>Methods that survive reality.</h2>
      <p>{siteMeta.institutions.join(" · ")}</p>
      {siteMeta.emails.map((email) => <a class="footer-email" href={`mailto:${email}`}>{email}</a>)}
    </div>
    <div><h3>Explore</h3>{pageSlugs.map((page) => <a href={getLocalizedPath(locale, page)}>{navigationLabels[page]}</a>)}</div>
    <div><h3>Profiles</h3>{siteMeta.socialLinks.map((link) => <a href={link.href} target="_blank" rel="noreferrer">{link.label}</a>)}</div>
    <div><h3>Company</h3><a class="wyld-text" href={siteMeta.wyldBloom} target="_blank" rel="noreferrer">WyldBloom ↗</a></div>
  </div>
  <div class="footer-bottom"><span>© {new Date().getFullYear()} Knowlton Lab</span><span>Statistical methods with clinical intent.</span></div>
</footer>
