---
import { localeNames, locales, type Locale, type PageSlug } from "../data/site";
import { getLocalizedPath } from "../lib/routing";

interface Props {
  locale: Locale;
  slug?: PageSlug | "";
}

const { locale, slug = "" } = Astro.props;
---

<div class="flex items-center gap-2 rounded-full border border-white/12 bg-white/6 p-1 text-xs text-sand-100/70">
  {locales.map((candidate) => {
    const isCurrent = candidate === locale;

    return (
      <a
        href={getLocalizedPath(candidate, slug)}
        class:list={[
          "rounded-full px-3 py-1.5 transition",
          isCurrent
            ? "bg-sand-100 text-ink-950"
            : "hover:bg-white/10 hover:text-sand-100"
        ]}
        aria-current={isCurrent ? "page" : undefined}
      >
        {localeNames[candidate]}
      </a>
    );
  })}
</div>
