---
import { homeContent, type Locale } from "../data/site";
import { outcomeClass, researchStreams } from "../data/sections";
import { getLocalizedPath } from "../lib/routing";
interface Props { locale: Locale; }
const { locale } = Astro.props;
const c = homeContent;
---
<section class="hero shell-wide">
  <p class="kicker">{c.kicker}</p>
  <h1>{c.titleBefore} <em>{c.titleAccent}</em> {c.titleAfter}</h1>
  <div class="hero-lead">
    <div><strong>{c.tagline}</strong><p>{c.lead}</p></div>
    <div class="hero-byline"><b>Dr Nicholas Knowlton</b>{c.byline.map((line) => <span>{line}</span>)}</div>
  </div>
</section>

<div class="editorial-layout shell-wide">
  <aside class="index-rail">
    <span class="mono-label">In this issue</span>
    <a href="#research">01 Research streams</a><a href="#wyldbloom">02 WyldBloom</a><a href="#people">03 People</a><a href="#work">04 Selected work</a><a href="#join">05 Join the lab</a>
    <div class="rail-stats">{c.stats.map((stat) => <div><strong>{stat.value}</strong><span>{stat.label}</span></div>)}</div>
  </aside>
  <div class="issue-content">
    <section class="issue-section" id="research">
      <header class="section-head"><span>01</span><h2>What the lab is <em>working on</em></h2><small>active streams</small></header>
      {researchStreams.map((stream) => <article class="stream-row"><b>{stream.area}</b><div><h3>{stream.question}</h3><p>{stream.summary}</p></div><div class="tag-list">{stream.outcomes.map((tag) => <span class:list={["outcome-tag", outcomeClass[tag] ?? "tag-teaching"]}>{tag}</span>)}</div></article>)}
      <a class="text-link" href={getLocalizedPath(locale, "research")}>Read the full research cases →</a>
    </section>

    <section class="issue-section wyld-feature" id="wyldbloom">
      <header class="section-head"><span>02</span><h2>Research that <em>left the building</em></h2><small>WyldBloom</small></header>
      <div class="wyld-intro"><img src="/media/wyldbloom-embryo.png" alt="Microscopy image of a developing human embryo" width="256" height="282" loading="lazy"/><div><p class="mono-label cyan">{c.wyldBloom.eyebrow}</p><h3>{c.wyldBloom.title}</h3><p>{c.wyldBloom.body}</p><a class="wyld-button" href={c.wyldBloom.href} target="_blank" rel="noreferrer">Visit WyldBloom ↗</a></div></div>
      <div class="video-frame">
        <video id="wyld-video" muted loop playsinline preload="metadata" poster="/media/wyldbloom-video-poster.png" aria-label={c.wyldBloom.videoLabel}><source src="/media/wyldbloom-embryo-review.mp4" type="video/mp4" /></video>
        <span>AI-derived morphology · developmental observations</span>
      </div>
    </section>

    <section class="issue-section" id="people">
      <header class="section-head"><span>03</span><h2>One cohort, <em>two institutions</em></h2><small>selected people</small></header>
      <div class="people-grid">{c.selectedPeople.map((person) => <article class="person-row"><div><b>{person.name}</b><span>{person.role}</span></div><p>“{person.question}”</p></article>)}</div>
      <a class="text-link" href={getLocalizedPath(locale, "students")}>Meet the full cohort →</a>
    </section>

    <section class="issue-section" id="work">
      <header class="section-head"><span>04</span><h2>Selected <em>work</em></h2><small>tagged by where it landed</small></header>
      <div class="publication-table">{c.featuredPublications.map((pub) => <a class="publication-row" href={pub.href} target="_blank" rel="noreferrer"><div><b>{pub.title}</b><span>{pub.venue}</span></div><time>{pub.year}</time><div class="tag-list">{pub.outcomes.map((tag) => <span class:list={["outcome-tag", outcomeClass[tag] ?? "tag-teaching"]}>{tag}</span>)}</div></a>)}</div>
      <a class="text-link" href={getLocalizedPath(locale, "publications")}>View publications →</a>
    </section>

    <section class="issue-section join-strip" id="join"><header class="section-head"><span>05</span><h2>Join the <em>lab</em></h2></header><div><h3>If a method can't survive messy data, it doesn't belong in the toolkit.</h3><p>I take students who want to build things that leave the building.</p><a class="primary-button" href={getLocalizedPath(locale, "join")}>How to join →</a></div></section>
  </div>
</div>

<script is:inline>
  (() => {
    const video = document.querySelector('#wyld-video');
    if (!video || matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const observer = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) video.play().catch(() => {}); else video.pause();
    }, { threshold: 0.35 });
    observer.observe(video);
  })();
</script>
