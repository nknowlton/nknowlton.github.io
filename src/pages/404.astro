---
import { defaultLocale } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getLocalizedPath } from "../lib/routing";
---
<BaseLayout locale={defaultLocale} page="home">
  <section class="page-hero shell-wide">
    <p class="kicker">404 · Page not found</p>
    <h1>This route has left the building.</h1>
    <p>The requested page is not part of the Knowlton Lab site.</p>
    <a class="primary-button" href={getLocalizedPath(defaultLocale)}>Return home →</a>
  </section>
</BaseLayout>
